GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-1.5-flash  # optional, defaults to gemini-2.5-flash
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/whatsapp-agent?retryWrites=true&w=majority

# Airtable (optional - logs every enquiry)
AIRTABLE_API_TOKEN=your_personal_access_token
AIRTABLE_BASE_ID=appxxxxxxxxxxxxxx
AIRTABLE_TABLE_ID=Enquiries
